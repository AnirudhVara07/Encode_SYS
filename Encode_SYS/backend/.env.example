# Never commit real values: keep secrets in backend/.env (gitignored). Use this file as a template only.
#
# --- Civic Auth (POST /auth code exchange; Log In uses PKCE + /callback on the current origin) ---
CIVIC_CLIENT_ID=
CIVIC_CLIENT_SECRET=
CIVIC_TOKEN_URL=https://auth.civic.com/oauth/token
# Fallback if the SPA omits redirect_uri (the app sends window.location.origin + /callback).
CIVIC_REDIRECT_URI=http://localhost:8080/callback
# Optional overrides:
# CIVIC_AUTHORIZE_URL=https://auth.civic.com/oauth/auth
# CIVIC_SCOPE=openid email profile
#
# The SPA sends prompt=login & max_age=0 on authorize so users see Civic sign-in again after Vigil log out
# (instead of silent SSO). If Civic rejects those params, ask Civic support or we can make them optional.
#
# In the Civic dashboard, register every redirect you use, e.g.:
#   http://localhost:8080/callback   (Vite dev)
#   http://localhost:8000/callback   (FastAPI-served SPA)
# Use the same host you type in the browser (localhost vs 127.0.0.1 are different).

# --- Session JWT after Civic (required for /status, /start, …) ---
SESSION_SIGNING_SECRET=change_me_to_a_long_random_string

# --- NewsAPI.org (GET /news, optional Vigil rule) ---
NEWSAPI_API_KEY=

# --- MarketAux (GET /api/marketaux-news — public headlines on marketing /) ---
MARKETAUX_API_TOKEN=
# If headlines vanish with a clear quota message, the MarketAux plan limit was hit — upgrade or wait for reset (see dashboard).

# NEWS_STRICT_MODE=true blocks Vigil automation when cached headlines match NEWS_MACRO_REGEX
# NEWS_MACRO_REGEX=CPI|FOMC|NFP|recession|Fed rate|GDP|inflation|unemployment

# --- Optional: Civic Bodyguard (LLM prompt/output screening — see Civic Labs / your account docs) ---
# When unset, Vigil still applies light local checks and optional output redaction; no HTTP calls are made.
# Point CIVIC_BODYGUARD_BASE_URL at the full screen endpoint URL from Civic (not only the host).
# CIVIC_BODYGUARD_BASE_URL=https://your-bodyguard-endpoint.example/screen
# CIVIC_BODYGUARD_API_KEY=
# Block when threat_score/score is >= threshold (0–1). Default 0.85.
# CIVIC_BODYGUARD_BLOCK_THRESHOLD=0.85
# Optional JSON merged into the request body (e.g. {"mode":"chat"}) if your deployment requires it.
# CIVIC_BODYGUARD_EXTRA_JSON=

# --- LLM: OpenRouter (default — strategy insights, /report, POST /api/strategy-chat) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OpenRouter model id (see https://openrouter.ai/models)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Optional: site URL / app name for OpenRouter rankings
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=Vigil

# --- Optional agent rules ---
# AGENT_MAX_TRADE_GBP=1000000
# (legacy) AGENT_MAX_TRADE_USD is still read if AGENT_MAX_TRADE_GBP is unset
# AGENT_MAX_TRADE_BTC=100
# AGENT_MIN_GBP_CASH_AFTER_BUY=0
# (legacy) AGENT_MIN_USD_CASH_AFTER_BUY is still read if AGENT_MIN_GBP_CASH_AFTER_BUY is unset
# AGENT_REQUIRE_SESSION=false

# --- Existing Vigil demo ---
# COINBASE_BEARER_JWT=
# Optional product for Vigil sandbox IOC + trading floor (default BTC-GBP)
# COINBASE_SANDBOX_PRODUCT_ID=BTC-GBP

# --- Human check before live trading (Civic = who you are; Turnstile = bot check each time) ---
# When TURNSTILE_SECRET_KEY is set, the SPA must send captcha_token on:
#   POST /api/coinbase-live/autopilot/start, POST /api/coinbase-live/trade, and POST /start with execution_mode live.
# Get keys: https://developers.cloudflare.com/turnstile/
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Real Coinbase trading (/real-trading, /api/coinbase-live/*) ---
# Recommended: preset CDP keys on the server (no UI paste; all signed-in users share this account).
# COINBASE_PRESET_API_KEY_ID=
# COINBASE_PRESET_API_KEY_SECRET=
# Trading pair for preview/orders (hyphenated, e.g. BTC-GBP for UK GBP wallets). Avoid BTC-USD unless your
# Coinbase profile actually trades that pair — wrong quote currency often yields "account is not available".
# COINBASE_PRESET_PRODUCT_ID=BTC-GBP

# Fernet key: encrypts CDP secrets in SQLite when using POST /api/coinbase-live/link (optional if you only use preset/org env keys).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# COINBASE_CREDENTIALS_FERNET_KEY=
# Optional SQLite path (default: backend/data/coinbase_live.db)
# COINBASE_LIVE_DB_PATH=/absolute/path/to/coinbase_live.db

# --- Optional: shared org Coinbase (COINBASE_ORG_*; same sharing rules as preset) ---
# COINBASE_ORG_TRADING=true
# COINBASE_ORG_API_KEY_ID=
# COINBASE_ORG_API_KEY_SECRET=
# Same as COINBASE_PRESET_PRODUCT_ID: use BTC-GBP for UK GBP cash; restart backend after changes.
# COINBASE_ORG_PRODUCT_ID=BTC-GBP
# Only one Live Vigil may run at a time org-wide (second user gets HTTP 409).

# --- Optional: on-chain attestation (fills, guardrails, kill-switch, strategy commitments, rollups) ---
# Deploy Encode_SYS/contracts/VigilFillAttestor.sol to Base Sepolia (or your chain), then set:
# VIGIL_FILL_ATTEST_RPC_URL=https://sepolia.base.org
# VIGIL_FILL_ATTEST_PRIVATE_KEY=0x...   # dedicated wallet; testnet-only recommended — never commit
# VIGIL_FILL_ATTEST_CONTRACT=0x...     # deployed VigilFillAttestor address (checksummed ok)
# Optional: override explorer link template (default maps chain id 84532 → sepolia.basescan, 8453 → basescan)
# VIGIL_FILL_ATTEST_EXPLORER_TX_URL=https://sepolia.basescan.org/tx/{tx_hash}
# If unset, all attestation is skipped and everything behaves as before.
#
# Merkle rollup: batch N fills into one on-chain tx (default 5). Set to 1 for per-fill rollups.
# VIGIL_ROLLUP_BATCH_SIZE=5
# Keep per-fill individual attestation alongside rollups (default off when rollup is active):
# VIGIL_FILL_ATTEST_PER_FILL=1
