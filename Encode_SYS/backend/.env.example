# Never commit real values: keep secrets in backend/.env (gitignored). Use this file as a template only.
#
# --- Civic Auth (POST /auth code exchange; Log In uses PKCE + /callback on the current origin) ---
CIVIC_CLIENT_ID=
CIVIC_CLIENT_SECRET=
CIVIC_TOKEN_URL=https://auth.civic.com/oauth/token
# Fallback if the SPA omits redirect_uri (the app sends window.location.origin + /callback).
CIVIC_REDIRECT_URI=http://localhost:8080/callback
# Optional overrides:
# CIVIC_AUTHORIZE_URL=https://auth.civic.com/oauth/auth
# CIVIC_SCOPE=openid email profile
#
# The SPA sends prompt=login & max_age=0 on authorize so users see Civic sign-in again after Vigil log out
# (instead of silent SSO). If Civic rejects those params, ask Civic support or we can make them optional.
#
# In the Civic dashboard, register every redirect you use, e.g.:
#   http://localhost:8080/callback   (Vite dev)
#   http://localhost:8000/callback   (FastAPI-served SPA)
# Use the same host you type in the browser (localhost vs 127.0.0.1 are different).

# --- Session JWT after Civic (required for /status, /start, …) ---
SESSION_SIGNING_SECRET=change_me_to_a_long_random_string

# --- NewsAPI.org (GET /news, optional Vigil rule) ---
NEWSAPI_API_KEY=

# --- MarketAux (GET /api/marketaux-news — public headlines on marketing /) ---
MARKETAUX_API_TOKEN=
# If headlines vanish with a clear quota message, the MarketAux plan limit was hit — upgrade or wait for reset (see dashboard).
# Optional: comma-separated entity_types (default: equity,index,etf,mutualfund,cryptocurrency,currency)
# MARKETAUX_ENTITY_TYPES=equity,index,etf

# NEWS_STRICT_MODE=true blocks Vigil automation when cached headlines match NEWS_MACRO_REGEX
# NEWS_MACRO_REGEX=CPI|FOMC|NFP|recession|Fed rate|GDP|inflation|unemployment

# --- LLM: OpenRouter (default — strategy insights, /report, POST /api/strategy-chat) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OpenRouter model id (see https://openrouter.ai/models)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Optional: site URL / app name for OpenRouter rankings
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=Vigil

# --- Optional agent rules ---
# AGENT_MAX_TRADE_USD=1000000
# AGENT_MAX_TRADE_BTC=100
# AGENT_MIN_USD_CASH_AFTER_BUY=0
# AGENT_REQUIRE_SESSION=false

# --- Existing Vigil demo ---
# COINBASE_BEARER_JWT=
